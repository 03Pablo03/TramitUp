# IA (Google AI Studio / Gemini)
GOOGLE_API_KEY=your_google_ai_studio_api_key_here

# Supabase (sin barra final)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here
SUPABASE_JWT_SECRET=your_supabase_jwt_secret_here

# Stripe - CONFIGURAR ESTAS VARIABLES
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret_here
STRIPE_PRICE_ID_DOCUMENT=price_your_document_price_id_here
STRIPE_PRICE_ID_PRO=price_your_pro_subscription_price_id_here

# App
FRONTEND_URL=http://localhost:3001
ENVIRONMENT=development

# Resend (alertas por email)
RESEND_API_KEY=your_resend_api_key_here
RESEND_FROM_EMAIL=alertas@tramitup.com
ALERTS_FROM_NAME=Tramitup Alertas

# Performance settings
MAX_CHAT_LENGTH=2000
RATE_LIMIT_FREE=2
RATE_LIMIT_PRO=100

# External APIs timeouts
GOOGLE_AI_TIMEOUT=30
SUPABASE_TIMEOUT=10